:{$OPENCODE_PORT} {
  # Reverse proxy OpenCode through Caddy so we can relax CSP enough
  # for the in-browser terminal's WASM worker to run.
  # OpenCode runs on the host (systemd) and listens on loopback.
  reverse_proxy {$OPENCODE_INTERNAL_HOSTNAME}:{$OPENCODE_INTERNAL_PORT} {
    # If OpenCode sets its own CSP header, browsers enforce the intersection
    # of multiple CSP headers. Strip upstream CSP first, then set ours below.
    header_down -Content-Security-Policy
  }

  # Replace upstream CSP (which blocks WASM instantiation in some browsers).
  # This policy is intentionally pragmatic for a Tailscale-only service.
  header Content-Security-Policy "default-src 'self' data: blob:; script-src 'self' 'unsafe-eval' 'wasm-unsafe-eval' blob:; worker-src 'self' blob:; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self' data:; connect-src 'self' ws: wss: data: blob:; object-src 'none'; base-uri 'self'"
}
