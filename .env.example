# OpenCode WebUI auth
OPENCODE_SERVER_USERNAME=opencode
OPENCODE_SERVER_PASSWORD=change-me

# Ports published on the droplet (firewalled to tailscale0)
OPENCODE_PORT=4096
LOGIN_PORTAL_PORT=3001

# OpenCode host-mode (when not running OpenCode in Docker)
# Caddy listens on OPENCODE_PORT and reverse-proxies to OPENCODE_INTERNAL_*.
OPENCODE_INTERNAL_HOSTNAME=127.0.0.1
OPENCODE_INTERNAL_PORT=4097

# File Browser (host mode)
# Default port is within the already-allowed dev range 8000-8099 on tailscale0.
FILEBROWSER_ADDRESS=0.0.0.0
FILEBROWSER_PORT=8001
FILEBROWSER_ROOT=/srv/agent/opencode-workspace
FILEBROWSER_DATABASE=/srv/agent/filebrowser/filebrowser.db

# Optional
TZ=UTC

# Images (override if you fork/host your own)
LOGIN_PORTAL_IMAGE=lscr.io/linuxserver/firefox:latest
